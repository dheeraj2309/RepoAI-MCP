# ==============================================================================
# Vector Databases & Local Vector Caches (ChromaDB / FAISS)
# ==============================================================================
# Keeps your vector indices and embeddings local to prevent pushing gigabytes of data
chroma/
*.chroma
.chromadb/
faiss_index/
*.index
*.pkl
*.pickle

# ==============================================================================
# MCP & LLM Framework Specifics (Claude Desktop / FastMCP Logs)
# ==============================================================================
# Ignore local runtime logs, prompts caches, or debug traces
.mcp/
mcp_logs/
*.log
claude_desktop_output.txt
.fastmcp/

# ==============================================================================
# Security & Credentials (CRITICAL for API Keys)
# ==============================================================================
# Never commit your OpenAI, Gemini, Claude, or Voyage API tokens
.env.*
!.env.example
secrets.toml
*.pem
*.key

